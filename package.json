{
  "name": "@cantoo/capacitor-audio-capture",
  "version": "0.1.1",
  "description": "Capacitor v7 plugin that captures microphone audio and streams raw PCM (base64 Float32) chunks to the consumer (web/Android/iOS).",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Sources",
    "ios/Tests",
    "Package.swift",
    "CantooCapacitorAudioCapture.podspec",
    "CHANGELOG.md"
  ],
  "author": "Cantoo",
  "license": "MIT",
  "homepage": "https://github.com/cantoo/capacitor-audio-capture#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cantoo/capacitor-audio-capture.git"
  },
  "bugs": {
    "url": "https://github.com/cantoo/capacitor-audio-capture/issues"
  },
  "keywords": [
    "capacitor",
    "capacitor-plugin",
    "capacitor-android",
    "capacitor-ios",
    "audio",
    "audio-capture",
    "audio-recording",
    "microphone",
    "pcm",
    "float32",
    "streaming",
    "audio-worklet"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "verify": "pnpm run verify:web",
    "verify:web": "pnpm run build",
    "lint": "biome check src",
    "fmt": "biome check --write src",
    "docgen": "docgen --api AudioCapturePlugin --output-readme README.md --output-json dist/docs.json",
    "build": "pnpm run clean && tsc && pnpm run inline-workers && rollup -c rollup.config.mjs",
    "inline-workers": "node scripts/inline-workers.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "pnpm run build"
  },
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/docgen": "^0.3.0",
    "@capacitor/ios": "^7.0.0",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.22.4",
    "typescript": "~5.4.5"
  },
  "peerDependencies": {
    "@capacitor/core": "^7.0.0"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
